# App
ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Postgres
POSTGRES_USER=psl
POSTGRES_PASSWORD=psl
POSTGRES_DB=psl
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://psl:psl@postgres:5432/psl

# Redis
REDIS_URL=redis://redis:6379/0

# Auth (set strong values in prod)
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
CSRF_SECRET=change-me-in-prod

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
